{
  "name": "serverest-cypress-tests",
  "version": "1.0.0",
  "description": "Testes E2E (UI) e de API para a aplicacao ServeRest usando Cypress e JavaScript",
  "author": "Davidzaque",
  "license": "MIT",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "test": "cypress run",
    "test:api": "cypress run --spec 'cypress/e2e/api/**/*.cy.js'",
    "test:ui": "cypress run --spec 'cypress/e2e/ui/**/*.cy.js'",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
    "cypress",
    "e2e",
    "api",
    "testing",
    "serverest",
    "javascript"
  ],
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "cypress": "^15.18.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^6.4.2",
    "globals": "^17.7.0",
    "prettier": "^3.9.4"
  }
}
