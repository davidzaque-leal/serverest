{
  "name": "serverest-cypress-tests",
  "version": "1.0.0",
  "description": "E2E (UI) and API automated tests for the ServeRest application using Cypress and JavaScript",
  "author": "Davidzaque",
  "license": "MIT",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:api": "cypress run --spec \"cypress/e2e/api/**/*.cy.js\"",
    "api:start": "serverest --port 3000",
    "stack:up": "docker compose up -d --build --wait",
    "stack:down": "docker compose down",
    "test": "cypress run",
    "test:ui": "cypress run --spec \"cypress/e2e/ui/**/*.cy.js\"",
    "test:api": "start-server-and-test api:start http://localhost:3000/usuarios cy:run:api",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
    "cypress",
    "e2e",
    "api",
    "testing",
    "serverest",
    "javascript"
  ],
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "cypress": "^15.18.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^6.4.2",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "serverest": "^3.2.0",
    "start-server-and-test": "^3.0.11"
  }
}
